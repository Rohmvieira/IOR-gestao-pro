# ══════════════════════════════════════════════════
# IOR Gestão Pro — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env no GitHub!
# ══════════════════════════════════════════════════

# Banco de dados PostgreSQL
DATABASE_URL=postgresql://usuario:senha@localhost:5432/ior_gestao

# Ambiente (development | production)
NODE_ENV=development

# Origens permitidas no CORS (separe por vírgula)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8081

# Tenant ID (para multi-tenancy futuro)
TENANT_ID=default

# JWT (para autenticação futura)
# JWT_SECRET=gere_uma_chave_forte_aqui_32_chars_min
# JWT_EXPIRES_IN=7d

# Porta da API (padrão 8080)
PORT=8080
