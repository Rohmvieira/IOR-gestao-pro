# ══════════════════════════════════════════════════
# IOR Gestão Pro — Variáveis de Ambiente
# Copie para .env e preencha os valores reais
# NUNCA commite o .env no GitHub!
# ══════════════════════════════════════════════════

# ── Supabase (banco de dados central)
SUPABASE_URL=https://odegosowuketirxdgllb.supabase.co
SUPABASE_ANON_KEY=sb_publishable_FoDiSdk9ynZ1yRDpJ1KDwg_B1c2S9E2
# Service role key: obtenha em supabase.com > Project Settings > API (NÃO expor no frontend)
SUPABASE_SERVICE_ROLE_KEY=OBTENHA_NO_PAINEL_SUPABASE

# ── PostgreSQL direto (para Drizzle ORM / migrations)
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# ── Criptografia AES-256-GCM (LGPD — campos sensíveis)
# Gere com: openssl rand -hex 32
ENCRYPTION_KEY=GERE_COM_openssl_rand_hex_32

# ── JWT para autenticação da API
# Gere com: openssl rand -base64 48
JWT_SECRET=GERE_COM_openssl_rand_base64_48
JWT_EXPIRES_IN=7d

# ── Redis (cache distribuído + rate limiting multi-pod)
REDIS_URL=redis://localhost:6379
# Em produção com senha: redis://:SUA_SENHA@redis-host:6379

# ── Express API
NODE_ENV=development
PORT=8080
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8081
TENANT_ID=default

# ── Frontend Vite
VITE_API_URL=http://localhost:8080/api
VITE_SUPABASE_URL=https://odegosowuketirxdgllb.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_FoDiSdk9ynZ1yRDpJ1KDwg_B1c2S9E2
